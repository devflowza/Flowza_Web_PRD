# Supabase — powers the public contact form and the /adm admin portal.
#
# Setup: copy this file to `.env` and fill in your project's values, OR set these
# as environment variables in your hosting / deployment settings (recommended).
# Without them the site still renders fine — only the contact form is disabled.
#
# The publishable (anon) key is meant to be exposed in the client bundle; security
# is enforced by Supabase Row Level Security, not by keeping this key secret.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-anon-key
